# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL + pgvector
DATABASE_URL=postgresql+asyncpg://wealth:wealth@localhost:5432/wealth_copilot

# App
BACKEND_CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Ingestion (SEC EDGAR — use a descriptive User-Agent per SEC policy)
SEC_USER_AGENT=YourName your.email@example.com
# Knowledge base: Apple + major brokerages / banks (10-K + 10-Q via SEC)
SEC_TICKERS=AAPL,RJF,JPM,MS,GS,SCHW

# Confidence routing (0.0–1.0 retrieval-based scores)
CONFIDENCE_REFUSE_THRESHOLD=0.35
CONFIDENCE_CAUTIOUS_THRESHOLD=0.55

# Retrieval (re-rank pool → top-k)
RETRIEVAL_TOP_K=10
RETRIEVAL_CANDIDATE_K=40
RETRIEVAL_MAX_CHUNK_CHARS=1800
DEBUG_RETRIEVAL=true
